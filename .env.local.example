# Copy this file to `.env.local` for local development (localhost values below are fine for dev).
#
# In production (Vercel → Settings → Environment Variables) set NEXT_PUBLIC_WEBSITE_URL
# to the real domain — it drives canonical URLs, OpenGraph/Twitter tags, robots.txt and
# the sitemap. Production value: https://hamedfarag.com

NEXT_PUBLIC_API_URL = "http://localhost:3000/api"
NEXT_PUBLIC_WEBSITE_URL = "http://localhost:3000"
